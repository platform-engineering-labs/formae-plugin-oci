amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@oci/oci.pkl"
import "@oci/identity/compartment.pkl"
import "@oci/identity/policy.pkl"

// These values need to be set for your OCI tenancy
local testCompartmentId = read("env:OCI_COMPARTMENT_ID")
local testProfile = read?("env:OCI_PROFILE") ?? "DEFAULT"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local testCompartment = new compartment.Compartment {
  label = "test-compartment"
  compartmentId = testCompartmentId
  name = "formae-sdk-test-\(testRunID)"
  description = "Conformance test compartment"
}

local stackName = "plugin-sdk-test-stack"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for OCI Policy"
  }

  new formae.Target {
    label = "oci-target"
    config = new oci.Config {
      profile = testProfile
      region = "us-chicago-1"
    }
  }

  testCompartment

  new policy.Policy {
    label = "plugin-sdk-test-policy"
    compartmentId = testCompartment.res.id
    // Changed policy name - this requires replacement (name is createOnly)
    name = "formae-plugin-sdk-test-\(testRunID)-replaced"
    description = "Policy for conformance tests"
    statements {
      "Allow group Administrators to inspect all-resources in compartment id \(testCompartmentId)"
    }
  }
}
