amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@oci/oci.pkl"
import "@oci/identity/compartment.pkl"
import "@oci/core/vcn.pkl"
import "@oci/core/subnet.pkl"

// These values need to be set for your OCI tenancy
local testCompartmentId = read("env:OCI_COMPARTMENT_ID")
local testProfile = read?("env:OCI_PROFILE") ?? "DEFAULT"
local testRunID = read("env:FORMAE_TEST_RUN_ID")

local testCompartment = new compartment.Compartment {
  label = "test-compartment"
  compartmentId = testCompartmentId
  name = "formae-sdk-test-\(testRunID)"
  description = "Conformance test compartment"
}

local stackName = "plugin-sdk-test-stack"

local testVcn = new vcn.VCN {
    label = "plugin-sdk-test-vcn"
    compartmentId = testCompartment.res.id
    cidrBlock = "10.0.0.0/16"
    displayName = "formae-plugin-sdk-test-\(testRunID)"
}

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK test for OCI Subnet"
  }

  new formae.Target {
    label = "oci-target"
    config = new oci.Config {
      profile = testProfile
      region = "us-chicago-1"
    }
  }

  testCompartment
  testVcn

  new subnet.Subnet {
    label = "plugin-sdk-test-subnet"
    compartmentId = testCompartment.res.id
    vcnId = testVcn.res.id
    cidrBlock = "10.0.1.0/24"
    // Changed displayName - this is an in-place update
    displayName = "formae-plugin-sdk-test-\(testRunID)-updated"
  }
}
