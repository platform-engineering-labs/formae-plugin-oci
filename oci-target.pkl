amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@oci/oci.pkl"

formae-plugin-oci/testdata/

forma {
  new formae.Target {
    label = "oci-target"
    discoverable = true
    config = new oci.Config {
      profile = testProfile
      region = "us-chicago-1"
    }
  }
}
