import "@formae/formae.pkl"
import "@oci/oci.pkl"

projectName = "dev-environment"
ociRegion = "us-chicago-1"

// Network config
vcnCidr = "10.0.0.0/16"
publicSubnetCidr = "10.0.1.0/24"

// Properties (CLI flags / env vars)
compartmentId = new formae.Prop {
    flag = "compartmentId"
    default = "ocid1.compartment.oc1..aaaaaaaalrlihjwxgvrupwi47au2aqy6rk3lfhm57bdrrq2ricjoi3sp6j5q"
}

availabilityDomain = new formae.Prop {
    flag = "availabilityDomain"
    default = "Twhb:US-CHICAGO-1-AD-1"
}

// Oracle Linux 8 image for us-chicago-1 (x86_64)
// Find images: oci compute image list --compartment-id <compartment-id> --operating-system "Oracle Linux" --shape "VM.Standard.E4.Flex"
imageId = new formae.Prop {
    flag = "imageId"
    default = "ocid1.image.oc1.us-chicago-1.aaaaaaaasyjphzjohvvrttbw66amaxx6otldb26fvvn4nsogrvzsq2t6vama"
}

// SSH public key for dev box access — set via SSH_PUBLIC_KEY env var.
// Example: SSH_PUBLIC_KEY="$(cat ~/.ssh/id_ed25519.pub)"
sshPublicKey = read("env:SSH_PUBLIC_KEY")

stack: formae.Stack = new {
    label = projectName
    description = "Dev environment: VM + scratch bucket on OCI"
}

target: formae.Target = new formae.Target {
    label = "oci-target"
    config = new oci.Config {
        region = module.ociRegion
    }
}
