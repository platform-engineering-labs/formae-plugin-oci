module platform.containers

import "@formae/formae.pkl"
import "@oci/oci.pkl"
import "@oci/core/vcn.pkl"
import "@oci/core/subnet.pkl"
import "@oci/containerengine/cluster.pkl"
import "@oci/containerengine/nodepool.pkl"
import "@oci/containerengine/virtualnodepool.pkl"

class ContainerResources {
    compartmentId: String
    projectName: String
    k8sVersion: String
    availabilityDomain: String
    nodeImageId: String
    vcn: vcn.VCN
    publicSubnet: subnet.Subnet
    privateSubnet: subnet.Subnet

    // Capture `this` so nested Listings can reach class-level fields
    // without `outer` resolving to the Listing itself.
    local _self = this

    hidden okeCluster: cluster.Cluster = new cluster.Cluster {
        label = "showcase-cluster"
        compartmentId = outer.compartmentId
        vcnId = vcn.res.id
        kubernetesVersion = k8sVersion
        name = projectName + "-cluster"

        endpointConfig = new cluster.ClusterEndpointConfig {
            subnetId = publicSubnet.res.id
            isPublicIpEnabled = true
        }

        options = new cluster.ClusterCreateOptions {
            serviceLbSubnetIds {
                publicSubnet.res.id
            }
            kubernetesNetworkConfig = new cluster.KubernetesNetworkConfig {
                podsCidr = "10.244.0.0/16"
                servicesCidr = "10.96.0.0/16"
            }
        }

        freeformTags {
            new oci.FreeformTag { key = "Name"; value = projectName + "-cluster" }
            new oci.FreeformTag { key = "Project"; value = projectName }
        }
    }

    hidden nodePool: nodepool.NodePool = new nodepool.NodePool {
        label = "showcase-nodepool"
        compartmentId = outer.compartmentId
        clusterId = okeCluster.res.id
        name = projectName + "-nodepool"
        kubernetesVersion = k8sVersion
        nodeShape = "VM.Standard.E4.Flex"

        nodeShapeConfig = new nodepool.NodeShapeConfig {
            ocpus = 2.0
            memoryInGBs = 16.0
        }

        nodeConfigDetails = new nodepool.NodeConfigDetails {
            size = 1
            placementConfigs {
                new nodepool.NodePoolPlacementConfig {
                    availabilityDomain = _self.availabilityDomain
                    subnetId = privateSubnet.res.id
                }
            }
        }

        nodeSourceDetails = new nodepool.NodeSourceViaImageDetails {
            imageId = nodeImageId
            bootVolumeSizeInGBs = 50
        }

        initialNodeLabels {
            new nodepool.NodeLabel {
                key = "environment"
                value = "showcase"
            }
        }

        freeformTags {
            new oci.FreeformTag { key = "Name"; value = projectName + "-nodepool" }
            new oci.FreeformTag { key = "Project"; value = projectName }
        }
    }

    hidden virtualNodePool: virtualnodepool.VirtualNodePool = new virtualnodepool.VirtualNodePool {
        label = "showcase-virtual-nodepool"
        compartmentId = outer.compartmentId
        clusterId = okeCluster.res.id
        displayName = projectName + "-virtual-nodepool"
        size = 1

        placementConfigurations {
            new virtualnodepool.PlacementConfiguration {
                availabilityDomain = _self.availabilityDomain
                subnetId = privateSubnet.res.id
            }
        }

        podConfiguration = new virtualnodepool.PodConfiguration {
            subnetId = privateSubnet.res.id
            shape = "Pod.Standard.E4.Flex"
        }

        freeformTags {
            new oci.FreeformTag { key = "Name"; value = projectName + "-virtual-nodepool" }
            new oci.FreeformTag { key = "Project"; value = projectName }
        }
    }

    hidden resources: Listing<formae.Resource> = new {
        okeCluster
        nodePool
        virtualNodePool
    }
}
